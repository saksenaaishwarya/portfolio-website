# ----------------------------------------------------------------------------
# Environment variables for the Aishwarya Saksena portfolio.
# Copy this file to `.env.local` and fill in values. All NEXT_PUBLIC_* vars are
# exposed to the browser — never put secrets here.
# ----------------------------------------------------------------------------

# Base path for GitHub Pages project deployments. Leave empty for local dev,
# a user/org page (<user>.github.io), or a custom domain. The CI workflow sets
# this automatically; only override if you rename/fork the repository.
# NEXT_PUBLIC_BASE_PATH=/portfolio-website

# Optional: Formspree form ID for the contact form. Create a free form at
# https://formspree.io and paste the ID (the part after /f/ in the endpoint).
# When unset, the contact form gracefully falls back to opening the visitor's
# email client via a mailto: link — so the site works with zero config.
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx
